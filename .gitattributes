# Mark all .flux files as FluxScript for GitHub Linguist detection
*.flux linguist-language=FluxScript linguist-detectable=true

# Test fixtures are FluxScript source, not generated
tests/flux/*.flux linguist-language=FluxScript linguist-detectable=true


# Vendor/third-party libraries should not appear in language stats
third_party/ linguist-vendored=true
*.o linguist-generated=true
*.so linguist-generated=true
build/ linguist-vendored=true
build_local/ linguist-vendored=true
