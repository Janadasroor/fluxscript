{
  "scopeName": "source.flux",
  "name": "FluxScript",
  "fileTypes": [".flux"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#interpolated_strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#annotations" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "//.*", "name": "comment.line.double-slash.flux" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.flux" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.double.flux"
        }
      ]
    },
    "interpolated_strings": {
      "patterns": [
        {
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.triple.flux"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "match": "\\b0x[0-9a-fA-F]+\\b", "name": "constant.numeric.hex.flux" },
        { "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b", "name": "constant.numeric.float.flux" },
        { "match": "\\b[0-9]+(?:[eE][+-]?[0-9]+)?\\b", "name": "constant.numeric.integer.flux" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(def|extern|let|var|if|then|else|elif|while|for|in|do|return|break|continue|match|switch|case|default|try|catch|throw|class|struct|enum|trait|impl|async|await|import|as|from|pub|mut|parallel|spawn|join|fn|pipe|to|self|null)\\b",
          "name": "keyword.control.flux"
        },
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.flux"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(double|float|int|bool|string|void|complex|vector|matrix|complexmatrix|auto|ModelOut)\\b",
          "name": "storage.type.flux"
        }
      ]
    },
    "operators": {
      "patterns": [
        { "match": "->|=>", "name": "keyword.operator.arrow.flux" },
        { "match": "\\+\\+|--|\\*\\*|\\.\\.", "name": "keyword.operator.misc.flux" },
        { "match": "==|!=|<=|>=|&&|\\|\\||!", "name": "keyword.operator.comparison.flux" },
        { "match": "\\+=|-=|\\*=|/=|%=|\\^=|\\|=", "name": "keyword.operator.assignment.flux" },
        { "match": "[+\\-*/%=^&|!<>]", "name": "keyword.operator.arithmetic.flux" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.flux"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "match": "\\b(PI|E|inf|nan|EPSILON)\\b", "name": "variable.other.constant.flux" }
      ]
    },
    "annotations": {
      "patterns": [
        { "match": "~[A-Za-z][A-Za-z0-9_]*", "name": "storage.annotation.flux" }
      ]
    },
    "identifiers": {
      "patterns": [
        { "match": "\\b(self)\\b", "name": "variable.language.self.flux" }
      ]
    }
  }
}
